# Contact email: use local|domain.com (joined at runtime) or base64-encoded full address
# Example split: nithish|gmail.com → nithish@gmail.com
# Example base64: run in terminal: node -e "console.log(Buffer.from('you@email.com').toString('base64'))"
VITE_CONTACT_EMAIL=your-name|your-domain.com

# Formspree form ID from https://formspree.io/ (endpoint: https://formspree.io/f/YOUR_ID)
VITE_FORMSPREE_ID=your-formspree-id
